# Copy this file to .env.production before building for production.
# Never commit .env.production — it is gitignored.

# Worker deployment URL (e.g. https://gap-weekend-alarm-worker.<subdomain>.workers.dev)
VITE_API_BASE_URL=https://your-worker.your-subdomain.workers.dev

# Cloudflare Turnstile Site Key (from Turnstile dashboard → your widget)
VITE_TURNSTILE_SITE_KEY=0x...
